# ━━━ AUTO-DISCOVERED AFTER FIRST CDK DEPLOY ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# These follow the naming convention or come from CDK outputs.
# Leave as-is for predictable defaults, or fill in after deploy.

# CloudFront / Frontend (from CDK output)
export APP_CLOUDFRONT_DOMAIN=""                     # e.g. dXXXXXXXXXXXXX.cloudfront.net
export APP_CLOUDFRONT_DISTRIBUTION_ID=""            # e.g. EXXXXXXXXXXXXXX
export APP_S3_WEBSITE_BUCKET="${APP_PREFIX}-website-${APP_AWS_ACCOUNT}"
