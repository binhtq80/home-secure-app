# Pipeline (predictable from prefix)
export APP_PIPELINE_NAME="${APP_PREFIX}-pipeline"

# DynamoDB Tables (predictable from prefix)
export APP_FEATURE_REQUESTS_TABLE="${APP_PREFIX}-feature-requests"
