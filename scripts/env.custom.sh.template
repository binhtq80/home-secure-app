# Required before first deploy

export APP_AWS_PROFILE="your-profile-name"
export APP_AWS_REGION="ap-southeast-2"
export APP_AWS_ACCOUNT="123456789012"
export APP_ENV_NAME="yourenv"
export APP_PREFIX="myapp-${APP_ENV_NAME}"

# GitHub (needed for pipeline / GitHub Actions)
export APP_GITHUB_OWNER="binhtq80"
export APP_GITHUB_REPO="myapp-infra"
