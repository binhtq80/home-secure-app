#!/bin/bash
# ─── Production Environment Configuration ─────────────────────────────────────
#
# Copy this file and fill in your production values:
#   cp scripts/env.prod.sh.template scripts/env.prod.sh
#   vim scripts/env.prod.sh
#
# Then use with:
#   ENV=prod ./scripts/deploy-frontend.sh
#   ENV=prod ./scripts/deploy-backend.sh
#
# ─────────────────────────────────────────────────────────────────────────────

# AWS
export APP_AWS_PROFILE="prod-admin"           # Your prod AWS CLI profile name
export APP_AWS_REGION="ap-southeast-2"        # Region for prod deployment
export APP_AWS_ACCOUNT="REPLACE_ME"           # Your prod AWS account ID

# Naming
export APP_PREFIX="myapp-prod"                # Resource name prefix
export APP_ENV_NAME="prod"

# CloudFront / Frontend (filled after first deploy)
export APP_CLOUDFRONT_DOMAIN="REPLACE_ME"                 # e.g., dXXXXXXXXXXX.cloudfront.net
export APP_CLOUDFRONT_DISTRIBUTION_ID="REPLACE_ME"        # e.g., E1XXXXXXXXXX
export APP_S3_WEBSITE_BUCKET="myapp-prod-website"         # CDK creates this
export APP_URL="https://REPLACE_ME"                       # Same as APP_CLOUDFRONT_DOMAIN

# Pipeline
export APP_PIPELINE_NAME="myapp-prod-pipeline"

# DynamoDB Tables (CDK creates these)
export APP_FEATURE_REQUESTS_TABLE="myapp-prod-feature-requests"
export APP_DEVICES_TABLE="myapp-prod-devices"
export APP_ENERGY_TABLE="myapp-prod-device-energy"

# GitHub
export APP_GITHUB_OWNER="binhtq80"            # Your GitHub username
export APP_GITHUB_REPO="myapp-infra"          # Repo name
export APP_GITHUB_BRANCH="main"              # Branch to deploy from
export APP_CONNECTION_ARN="REPLACE_ME"        # AWS CodeConnections ARN (create in console)
export APP_GITHUB_ACTIONS_ROLE="REPLACE_ME"   # Filled after OIDC stack deploy

# Bedrock
export APP_BEDROCK_MODEL_ID="au.anthropic.claude-haiku-4-5-20251001-v1:0"
