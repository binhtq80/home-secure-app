{
  "name": "myapp",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "infrastructure"
  ],
  "scripts": {
    "build:frontend": "yarn workspace frontend build",
    "build:backend": "yarn workspace backend build",
    "build:infra": "yarn workspace infrastructure build",
    "start:frontend": "yarn workspace frontend dev",
    "deploy:infra": "yarn workspace infrastructure deploy",
    "deploy": "yarn build:backend && yarn build:frontend && yarn deploy:infra"
  },
  "engines": {
    "node": ">=20"
  }
}
