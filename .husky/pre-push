#!/bin/bash
# ─── Hybrid Pre-Push Hook: Deterministic + Agentic ───────────────────────────
# 
# Step 1: Deterministic — "Will it build?" (blocks on failure)
# Step 2: Agentic — "Should it ship?" (warns or blocks)
#
# To skip all checks: git push --no-verify
# To skip only agentic: SKIP_AI_REVIEW=1 git push
# ─────────────────────────────────────────────────────────────────────────────

set -e

ROOT_DIR="$(git rev-parse --show-toplevel)"

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🔒 Pre-Push Validation (hybrid: rules + AI)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ─── Step 1: Deterministic Checks ─────────────────────────────────────────────
echo ""
echo "📐 Step 1: Deterministic checks (build simulation)"
echo ""

if [ -d "$ROOT_DIR/frontend/node_modules" ] && [ -d "$ROOT_DIR/infrastructure/node_modules" ]; then
  "$ROOT_DIR/scripts/simulate-pipeline.sh" --quick
else
  "$ROOT_DIR/scripts/simulate-pipeline.sh"
fi

# ─── Step 2: Agentic Review ──────────────────────────────────────────────────
if [ "${SKIP_AI_REVIEW:-0}" = "1" ]; then
  echo ""
  echo "⏭️  AI review skipped (SKIP_AI_REVIEW=1)"
  exit 0
fi

# Check if kiro-cli is available
KIRO_CLI="/agentspaces/kiro-cli.latest/kiro-cli"
if [ ! -x "$KIRO_CLI" ]; then
  # Try PATH as fallback
  KIRO_CLI=$(command -v kiro-cli 2>/dev/null || echo "")
fi

if [ -z "$KIRO_CLI" ]; then
  echo ""
  echo "⏭️  AI review skipped (kiro-cli not found)"
  echo "   Install kiro-cli to enable agentic pre-push review"
  exit 0
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🤖 Step 2: AI review (analyzing changes)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Get the diff against the remote main branch
DIFF=$(git diff origin/main..HEAD 2>/dev/null || git diff HEAD~1..HEAD 2>/dev/null || echo "")

if [ -z "$DIFF" ]; then
  echo "   No changes to review."
  exit 0
fi

# Get list of changed files for context
CHANGED_FILES=$(git diff --name-only origin/main..HEAD 2>/dev/null || git diff --name-only HEAD~1..HEAD 2>/dev/null || echo "")

# Write diff to a temp file (avoid arg length limits)
DIFF_FILE=$(mktemp)
echo "$DIFF" > "$DIFF_FILE"

# Run kiro-cli review
REVIEW_RESULT=$("$KIRO_CLI" chat --no-interactive "Review this git diff for a monorepo (React frontend, Node.js Lambda backend, AWS CDK infrastructure). Check ONLY for: 1) Security issues (missing auth, exposed secrets) 2) Breaking changes (API/frontend mismatch) 3) Infra-code mismatch (unwired Lambda, missing env vars) 4) Runtime errors (null refs, unhandled exceptions) 5) Data loss risks. DO NOT flag style, tests, or docs. Changed files: $CHANGED_FILES. Respond starting with PASS, WARN, or BLOCK followed by a brief explanation.

$(cat "$DIFF_FILE")" 2>&1 | sed 's/\x1B\[[0-9;]*[a-zA-Z]//g' | sed 's/\x1B\[[?][0-9]*[a-zA-Z]//g' | grep -v "mcp server" | grep -v "Credits:" | grep -v "^------" | grep -v "^[[:space:]]*▸" | grep -v "^[[:space:]]*$" | head -10 || echo "PASS: AI review unavailable")

# Clean up
rm -f "$DIFF_FILE"

# Parse result
echo "   $REVIEW_RESULT"
echo ""

if echo "$REVIEW_RESULT" | grep -qi "^BLOCK"; then
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "🚫 Push BLOCKED by AI review"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "   Fix the issue above, or override with:"
  echo "   SKIP_AI_REVIEW=1 git push"
  echo ""
  exit 1
elif echo "$REVIEW_RESULT" | grep -qi "^WARN"; then
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "⚠️  AI review: warning noted, push proceeding"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
else
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "✅ AI review passed"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
fi
